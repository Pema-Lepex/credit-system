# ---------------------------------------------------------------------------
# Copy to .env and edit. Never commit .env.
#
# Every value here has a working default, so the app boots with an empty .env.
# The three you WILL want to change before going live are marked  ** REQUIRED **.
# ---------------------------------------------------------------------------

# --- App -------------------------------------------------------------------
APP_NAME="Credit Management System"
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # ** REQUIRED ** set false in production
                                 # (GraphiQL + /docs + schema introspection are
                                 #  all gated on this. Leaving it true in
                                 #  production hands out a schema browser.)

# --- Security --------------------------------------------------------------
# ** REQUIRED ** in production. Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app REFUSES to boot in production while this is the placeholder.
SECRET_KEY=dev-only-insecure-secret-change-me

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated. ** REQUIRED ** add your deployed frontend origin.
CORS_ORIGINS=http://localhost:3000

# --- Database --------------------------------------------------------------
# DEV (default): SQLite in /database/app.db. Zero config, fine for one shop.
#
# PRODUCTION: Postgres. NOT optional on an ephemeral host -- Render/Fly/Vercel rebuild
# the container filesystem on every deploy, so a SQLite file (and every customer,
# credit and payment in it) is DESTROYED on each redeploy. The app now refuses to boot
# with ENVIRONMENT=production + SQLite rather than let that happen quietly.
#
# Paste the connection string EXACTLY as your provider prints it. `postgres://…` and
# `postgresql://…` are both rewritten to `postgresql+psycopg://` for you.
#
#   Supabase  Project -> Settings -> Database -> Connection string -> URI
#             DATABASE_URL=postgres://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
#   Neon      DATABASE_URL=postgres://user:pw@ep-xxx.neon.tech/neondb?sslmode=require
#   Render    DATABASE_URL=<the Internal Database URL from the dashboard>
#
# Already have data in SQLite? Copy it across ONCE, after creating the schema:
#   alembic upgrade head                       # against the new DATABASE_URL
#   python scripts/migrate_sqlite_to_postgres.py \
#       --source sqlite:///../database/app.db --target "$DATABASE_URL" --dry-run
#
# DATABASE_URL=sqlite:///./database/app.db
DB_ECHO=false
DB_POOL_SIZE=5                   # ignored by SQLite, honoured by Postgres
DB_MAX_OVERFLOW=10

# --- Storage ---------------------------------------------------------------
# local      => writes to /uploads. The dev default. EPHEMERAL on Render/Fly/Vercel:
#               every uploaded photo, logo and receipt is gone on the next redeploy.
#               Refused in production for exactly that reason.
# cloudinary => the production default. Free tier, no card, CDN-backed. Survives deploys.
# s3         => AWS S3, Cloudflare R2, Supabase Storage, MinIO. Needs: pip install boto3
#
# All three implement the same Protocol (app/storage/base.py). Switching backends
# changes NOTHING else: no service, resolver or model touches a filesystem path.
STORAGE_BACKEND=local

MAX_UPLOAD_MB=10
IMAGE_MAX_DIMENSION=1600         # long edge; larger images are downscaled
IMAGE_QUALITY=82                 # WebP quality after compression
THUMBNAIL_DIMENSION=320

# Only read when STORAGE_BACKEND=cloudinary.
#
# Sign up at cloudinary.com (free, no card). The dashboard shows one value --
#     CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# -- paste it here and you are done. The three-part form below is for secret managers
# that dislike URL-shaped values; the single URL wins if both are set.
# CLOUDINARY_URL=cloudinary://123456789:abcdefg@your-cloud-name
#
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
#
# Namespaces every object, so one Cloudinary account can host staging and production
# without them overwriting each other's files.
CLOUDINARY_FOLDER=credit-system

# Only read when STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com   # omit for real AWS
# S3_REGION=auto
# S3_BUCKET=credit-system
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.example.com                      # optional CDN

# --- Email -----------------------------------------------------------------
# console => logs the email instead of sending. The dev default.
# w3forms => FREE, but a form-to-email RELAY: it can only deliver to the inbox
#            registered against your access key. It CAN notify the business owner.
#            It CANNOT email your customers. Customer reminders will be recorded
#            as FAILED (loudly, on purpose) rather than silently dropped.
# smtp    => any SMTP server. THIS is what makes customer reminders work.
EMAIL_PROVIDER=console

EMAIL_FROM_NAME="Credit Management System"
EMAIL_FROM_ADDRESS=no-reply@localhost

# W3Forms (owner notifications only -- see above)
# W3FORMS_ACCESS_KEY=your-access-key-from-web3forms.com

# SMTP -- required for customer-facing reminders.
# Free tiers: Brevo (300/day), Resend (3k/mo), or a Gmail app password.
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# --- Scheduler -------------------------------------------------------------
# The reminder + maintenance jobs run IN THIS PROCESS (APScheduler).
#
# Two consequences you must know:
#   1. On serverless (Vercel/Lambda) there is no long-lived process, so the
#      scheduler NEVER FIRES and no reminder is ever sent. Deploy the backend to
#      a persistent host (Fly/Railway/Render/VPS).
#   2. If you run MORE THAN ONE instance, every instance schedules the same jobs.
#      They are idempotent, so this is wasteful rather than catastrophic -- but set
#      SCHEDULER_ENABLED=false on all but one instance.
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC           # jobs pick each business's own tz for send times

# --- External cron (REQUIRED on a free/sleeping host) ------------------------
# Point a free cron service at the app hourly so reminders fire even when the host
# has slept the process:
#
#   POST https://your-api.example.com/api/cron/reminders
#   Authorization: Bearer <CRON_SECRET>
#
# The request wakes the host and runs the same sweep the in-process scheduler
# would have. Safe to call as often as you like -- the jobs are idempotent, and a
# business outside its send-hour is skipped in microseconds. Jobs: reminders,
# daily, weekly, monthly.
#
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave unset and the endpoint returns 503 and runs nothing (it fails closed).
# CRON_SECRET=

# There is deliberately no global "reminder hour" or "retention days" setting --
# both are PER-BUSINESS (Settings -> Reminders / Data Retention in the app), because a
# single global value would be wrong for every tenant but one.

# --- Retention / storage hygiene -------------------------------------------
EXPORT_TTL_HOURS=24              # generated exports self-destruct after this
ARCHIVE_GRACE_DAYS=7             # gap between archiving and the earliest deletion

# --- Pagination ------------------------------------------------------------
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100                # hard cap; protects against limit=1000000

# --- Demo seed (dev only) --------------------------------------------------
FIRST_SUPERADMIN_EMAIL=admin@creditsystem.local
FIRST_SUPERADMIN_PASSWORD=ChangeMe123!

# --- Super Admin (the ONE platform operator) -------------------------------
# The single platform administrator. Credentials are read from the environment
# and are NEVER hardcoded in the frontend. On boot, a SUPER_ADMIN user row is
# created/reconciled from these values (app/db/bootstrap.py), so signing in uses
# the ordinary JWT flow. Leave unset to run without a platform operator.
#
#   SUPER_ADMIN_EMAIL=you@example.com
#   SUPER_ADMIN_PASSWORD=change-this-strong-password
#
# W3Forms key whose registered inbox is the super-admin's -- used only to notify
# the operator when a new store owner registers (owner-facing mail, which W3Forms
# can deliver). Separate from W3FORMS_ACCESS_KEY, whose destination is a tenant.
#
#   SUPER_ADMIN_W3FORMS_ACCESS_KEY=your-web3forms-access-key
